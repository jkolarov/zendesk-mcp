# ─── Required ──────────────────────────────────────────────────────────────
ZD_SUBDOMAIN=your-subdomain        # Subdomain only — e.g. "acme", not "acme.zendesk.com"

# ─── Authentication — choose ONE of the three options below ────────────────

# ── Option 1: OAuth — Client Credentials (recommended for server/automated use)
# Create an OAuth client at: Admin Center → Apps & Integrations → OAuth Clients
# Use the Client ID and Client Secret shown on that page.
#
# ⚠️  ZD_OAUTH_CLIENT_SECRET is the *client secret*, NOT an access token.
#     The server exchanges it automatically for an access token on every startup.
#     Client ID and Client Secret never expire — no manual rotation needed.
#
ZD_OAUTH_CLIENT_ID=your_oauth_client_id
ZD_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# ZD_OAUTH_SCOPE=read write        # Optional. Default: "read write"

# ── Option 2: API Token
# Generate at: Admin Center → Apps & Integrations → Zendesk API → Add API token
#
# ZD_EMAIL=admin@yourcompany.com
# ZD_API_TOKEN=your_api_token_here

# ── Option 3: OAuth — Static Access Token (manual rotation required)
# Obtain via the OAuth authorization flow, or click "Generate Token" on the
# OAuth Clients page. Tokens expire per your Zendesk configuration (up to 30 days).
# You must replace this value manually when it expires.
#
# ZD_OAUTH_TOKEN=your_static_access_token_here

# ─── Optional tuning ───────────────────────────────────────────────────────
# TOOLS_MAX_PER_PAGE=100
# TOOLS_MAX_PAGES=100
