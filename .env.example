# ─── Required ──────────────────────────────────────────────────────────────
ZD_SUBDOMAIN=your-subdomain        # Subdomain only — e.g. "acme", not "acme.zendesk.com"

# ─── Authentication — choose ONE of the three options below ────────────────

# ── Option 1: OAuth — Refresh Token (recommended for server/automated use)
#
# Two-step setup (admin does this once):
#
#   Step 1 — Create a confidential OAuth client in Zendesk:
#     Admin Center → Apps & Integrations → OAuth Clients → Add OAuth Client
#     Set "Client type" to Confidential. Note the Client ID and Client Secret.
#
#   Step 2 — Generate a refresh token using the Zendesk admin API:
#     curl -X POST https://<subdomain>.zendesk.com/api/v2/oauth/tokens.json \
#       -u "admin@company.com/token:<api_token>" \
#       -H "Content-Type: application/json" \
#       -d '{"token": {"client_id": <numeric_client_id>, "scopes": ["read", "write"]}}'
#     Copy the "refresh_token" value from the response — Zendesk shows it only once.
#
# Give the agent the three values below. The server mints short-lived access
# tokens automatically on startup and re-mints them on expiry.
# Refresh tokens expire after 30 days — repeat Step 2 to get a new one.
#
ZD_OAUTH_CLIENT_ID=your_oauth_client_identifier
ZD_OAUTH_CLIENT_SECRET=your_oauth_client_secret
ZD_OAUTH_REFRESH_TOKEN=your_refresh_token

# ── Option 2: API Token
# Generate at: Admin Center → Apps & Integrations → Zendesk API → Add API token
#
# ZD_EMAIL=admin@yourcompany.com
# ZD_API_TOKEN=your_api_token_here

# ── Option 3: OAuth — Static Access Token (manual rotation required)
# Use the "token" value (not "refresh_token") from the Step 2 curl above,
# or generate one via the Zendesk UI. Expires per your Zendesk config (up to 30 days).
# You must replace this value manually when it expires.
#
# ZD_OAUTH_TOKEN=your_static_access_token_here

# ─── Optional tuning ───────────────────────────────────────────────────────
# TOOLS_MAX_PER_PAGE=100
# TOOLS_MAX_PAGES=100
